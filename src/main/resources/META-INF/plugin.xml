<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>ke.co.coterie.plugins.glb-viewer</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Glb-Viewer</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://coterie.ke">Coterie Kenya</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Enter short description for your plugin here.<br>
        <em>most HTML tags may be used</em>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>

    <applicationListeners>
        <listener class="ke.co.coterie.plugins.glbviewer.GlbApplicationListener" topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.glbviewer.GlbViewerWidgetFactory" id="ke.co.coterie.plugins.glb-viewer.wireframe-status-bar"/>
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.glbviewer.GlbAnimationWidgetFactory" id="ke.co.coterie.plugins.glb-viewer.animation-status-bar"/>
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.glbviewer.GlbAnimationSelectorWidgetFactory" id="ke.co.coterie.plugins.glb-viewer.animation-selector-status-bar"/>
        <fileType
                name="GLB"
                implementationClass="ke.co.coterie.plugins.glbviewer.GlbFileType"
                fieldName="INSTANCE"
                language="GLB"
                extensions="glb"/>
        <fileEditorProvider implementation="ke.co.coterie.plugins.glbviewer.GlbEditorProvider" />
    </extensions>
</idea-plugin>