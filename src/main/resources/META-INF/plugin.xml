<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>ke.co.coterie.plugins.model3d-viewer</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>3D-Model-Viewer</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://coterie.ke">Coterie Kenya</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
<p>View and inspect 3D models directly in your IntelliJ-based IDE.</p>

<h2>Features</h2>
<ul>
    <li>View 3D models directly in the editor</li>
    <li>Wireframe mode toggle via status bar</li>
    <li>Auto-rotate toggle via status bar</li>
    <li>Animation playback controls (play/pause)</li>
    <li>Animation selector for models with multiple animations</li>
    <li>Model Explorer tool window: browse the internal structure (materials, meshes, accessors, images, &hellip;) of GLB/GLTF files, with click-to-navigate the glTF JSON and material highlighting in the preview</li>
</ul>

<h2>Supported File Formats</h2>
<ul>
    <li><b>GLB</b>: Built-in support, works out of the box</li>
    <li><b>GLTF</b>: Built-in support, automatically bundles referenced assets (textures, binary files)</li>
    <li><b>STL</b>: Built-in support, geometry only (binary and ASCII)</li>
    <li><b>three.js JSON</b>: Built-in support for three.js model JSON (BufferGeometry / Object / Scene). Detected by content, so ordinary <code>.json</code> files keep their normal JSON editor plus an editor/preview toggle.</li>
    <li><b>OBJ</b>: Optional support, enable in <b>Settings &gt; Tools &gt; 3D Model Viewer</b>.<br/>
        <em>OBJ support is opt-in because other plugins may also register the .obj file extension. Requires IDE restart after enabling.</em>
    </li>
</ul>

<h2>Installation</h2>

<h3>From JetBrains Marketplace</h3>
<ol>
    <li>Open <b>Settings</b> → <b>Plugins</b> → <b>Marketplace</b></li>
    <li>Search for "3D-Model-Viewer"</li>
    <li>Click <b>Install</b></li>
    <li>Restart IDE if prompted</li>
</ol>

<h3>From GitHub Releases</h3>
<ol>
    <li>Download the latest .zip file from <a href="https://github.com/iz-ben/3d-model-viewer/releases">GitHub Releases</a></li>
    <li>Open <b>Settings</b> → <b>Plugins</b></li>
    <li>Click the ⚙️ icon → <b>Install Plugin from Disk...</b></li>
    <li>Select the downloaded zip file</li>
    <li>Restart IDE if prompted</li>
</ol>

<h2>Usage</h2>
<ol>
    <li>Open any supported 3D model file (.glb, .gltf, .stl, or .obj if enabled)</li>
    <li>The model will render in the editor tab</li>
    <li>Use the status bar widgets at the bottom to toggle <b>Wireframe</b> mode, <b>Auto-rotate</b>, <b>Play/Pause</b> animations, or select animations</li>
</ol>

<h2>Support</h2>
<p>If you find this plugin useful, consider supporting its development:</p>
<p>☕ <a href="https://buymeacoffee.com/coterieke">Buy Me a Coffee</a></p>

<h2>Links</h2>
<ul>
    <li><a href="https://github.com/iz-ben/3d-model-viewer">GitHub Repository</a></li>
    <li><a href="https://github.com/iz-ben/3d-model-viewer/issues">Report Issues</a></li>
</ul>
    ]]></description>

    <!-- Change notes are injected automatically at build time from CHANGELOG.md
         for the current pluginVersion (see the changelog config in build.gradle.kts).
         Do not edit this by hand. -->
    <change-notes></change-notes>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>com.intellij.modules.jcef</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- Status bar widgets -->
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.model3dviewer.Model3DViewerWidgetFactory" id="Model3DViewerWireframeWidget"/>
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.model3dviewer.Model3DAutoRotateWidgetFactory" id="Model3DViewerAutoRotateWidget"/>
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.model3dviewer.Model3DAnimationWidgetFactory" id="Model3DViewerAnimationWidget"/>
        <statusBarWidgetFactory implementation="ke.co.coterie.plugins.model3dviewer.Model3DAnimationSelectorWidgetFactory" id="Model3DViewerAnimationSelectorWidget"/>

        <!-- File types - GLB (static registration) -->
        <fileType
                name="GLB"
                implementationClass="ke.co.coterie.plugins.model3dviewer.Model3DFileType"
                fieldName="INSTANCE"
                language="3DModel"
                extensions="glb"/>

        <!-- File types - GLTF (static registration) -->
        <fileType
                name="GLTF"
                implementationClass="ke.co.coterie.plugins.model3dviewer.GltfFileType"
                fieldName="INSTANCE"
                language="GLTF"
                extensions="gltf"/>

        <!-- File types - STL (static registration) -->
        <fileType
                name="STL"
                implementationClass="ke.co.coterie.plugins.model3dviewer.StlFileType"
                fieldName="INSTANCE"
                language="STL"
                extensions="stl"/>

        <!-- File editor provider for 3D model files -->
        <fileEditorProvider implementation="ke.co.coterie.plugins.model3dviewer.Model3DEditorProvider"/>
        <fileEditorProvider implementation="ke.co.coterie.plugins.model3dviewer.Model3DJsonEditorProvider"/>

        <!-- Application services -->
        <applicationService serviceImplementation="ke.co.coterie.plugins.model3dviewer.Model3DSettings"/>

        <!-- Settings configurable -->
        <applicationConfigurable
                parentId="tools"
                instance="ke.co.coterie.plugins.model3dviewer.Model3DSettingsConfigurable"
                id="ke.co.coterie.plugins.model3dviewer.settings"
                key="settings.display.name"
                bundle="messages.MyMessageBundle"/>

        <!-- Notification group for restart notifications -->
        <notificationGroup id="Model3DViewer.Notifications" displayType="BALLOON"/>

        <!-- Startup activity to initialize OBJ file type registration -->
        <postStartupActivity implementation="ke.co.coterie.plugins.model3dviewer.ObjFileTypeStartupActivity"/>
        <!-- Sets initial glTF Structure tool window visibility for a restored glTF/GLB tab -->
        <postStartupActivity implementation="ke.co.coterie.plugins.model3dviewer.GltfStructureStartupActivity"/>
        <!-- Marks the Got It tooltip state ready once the project has finished opening -->
        <postStartupActivity implementation="ke.co.coterie.plugins.model3dviewer.Model3DJsonGotItStartupActivity"/>

        <!-- Tool window revealing the internal structure of the active glTF/GLB file.
             Hidden by default; shown only while a .glb/.gltf file is in focus. -->
        <toolWindow id="Model Explorer"
                    anchor="right"
                    secondary="true"
                    icon="AllIcons.Toolwindows.ToolWindowStructure"
                    factoryClass="ke.co.coterie.plugins.model3dviewer.GltfStructureToolWindowFactory"/>
    </extensions>

    <projectListeners>
        <!-- Shows a one-time Got It tooltip when a three.js model JSON is first opened. -->
        <listener class="ke.co.coterie.plugins.model3dviewer.Model3DJsonGotItListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
        <!-- Toggles the glTF Structure tool window stripe based on the focused file. -->
        <listener class="ke.co.coterie.plugins.model3dviewer.GltfStructureAvailabilityListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>
</idea-plugin>